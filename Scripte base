-- TRIGGERS
---------------------------------------------------------

-- Audit des modifications de Personne
CREATE TRIGGER TRG_Personne_Audit
ON Personne
FOR UPDATE
AS
BEGIN
    INSERT INTO PersonneAudit (
        ActionType, OldNom, OldPrenom, OldEmail, OldTelephone, OldAdresse,
        NewNom, NewPrenom, NewEmail, NewTelephone, NewAdresse, ActionDate, idPersonne
    )
    SELECT
        'UPDATE',
        d.Nom, d.Prenom, d.Email, d.Telephone, d.Adresse,
        i.Nom, i.Prenom, i.Email, i.Telephone, i.Adresse,
        CONVERT(DATE, GETDATE()),
        d.idPersonne
    FROM deleted d
    JOIN inserted i ON d.idPersonne = i.idPersonne;
END;
GO

-- Empêcher la suppression d’un abonnement utilisé
CREATE TRIGGER TRG_NoDeleteAbonnement
ON Abonnement
INSTEAD OF DELETE
AS
BEGIN
    IF EXISTS (SELECT 1 FROM Personne WHERE idAbonnement IN (SELECT idAbonnement FROM deleted))
    BEGIN
        RAISERROR('Impossible de supprimer un abonnement utilisé.', 16, 1);
        RETURN;
    END

    DELETE FROM Abonnement WHERE idAbonnement IN (SELECT idAbonnement FROM deleted);
END;
GO

-- Empêcher la suppression d’un article lié à un animal
CREATE TRIGGER TRG_NoDeleteArticle
ON Article
INSTEAD OF DELETE
AS
BEGIN
    IF EXISTS (SELECT 1 FROM Animal WHERE idArticle IN (SELECT idArticle FROM deleted))
    BEGIN
        RAISERROR('Impossible de supprimer un article lié à un animal.', 16, 1);
        RETURN;
    END

    DELETE FROM Article WHERE idArticle IN (SELECT idArticle FROM deleted);
END;
GO
