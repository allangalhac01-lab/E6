---------------------------------------------------------
-- PROCEDURES STOCKÉES
---------------------------------------------------------

-- Créer une personne
CREATE PROCEDURE CreatePersonne
    @Nom VARCHAR(50),
    @Prenom VARCHAR(50),
    @Email VARCHAR(50),
    @Telephone INT,
    @MotDePasse VARCHAR(50),
    @Adresse VARCHAR(50),
    @idAbonnement INT = NULL
AS
BEGIN
    INSERT INTO Personne (Nom, Prenom, Email, Telephone, MotDePasse, Adresse, idAbonnement)
    VALUES (@Nom, @Prenom, @Email, @Telephone, @MotDePasse, @Adresse, @idAbonnement);

    SELECT SCOPE_IDENTITY() AS NewPersonneId;
END;
GO

-- Créer un animal
CREATE PROCEDURE CreateAnimal
    @Nom VARCHAR(50),
    @Age INT,
    @Sexe VARCHAR(50),
    @Espece VARCHAR(50),
    @idArticle INT
AS
BEGIN
    INSERT INTO Animal (Nom, Age, Sexe, Espece, idArticle)
    VALUES (@Nom, @Age, @Sexe, @Espece, @idArticle);

    SELECT SCOPE_IDENTITY() AS NewAnimalId;
END;
GO

-- Supprimer une personne
CREATE PROCEDURE DeletePersonne
    @idPersonne INT
AS
BEGIN
    DELETE FROM Personne WHERE idPersonne = @idPersonne;
END;
GO

