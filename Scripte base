
---------------------------------------------------------
-- TABLE : Abonnement
---------------------------------------------------------
CREATE TABLE Abonnement (
    idAbonnement INT IDENTITY(1,1) PRIMARY KEY,
    NomAbonnement VARCHAR(50),
    Prix DECIMAL(15,2),
    DureeEnJours DATE
);

---------------------------------------------------------
-- TABLE : Personne
---------------------------------------------------------
CREATE TABLE Personne (
    idPersonne INT IDENTITY(1,1) PRIMARY KEY,
    Nom VARCHAR(50),
    Prenom VARCHAR(50),
    Email VARCHAR(50),
    Telephone INT,
    MotDePasse VARCHAR(50),
    Adresse VARCHAR(50),
    idAbonnement INT NULL,
    FOREIGN KEY (idAbonnement) REFERENCES Abonnement(idAbonnement)
);

---------------------------------------------------------
-- TABLE : Role
---------------------------------------------------------
CREATE TABLE Role (
    idRole INT IDENTITY(1,1) PRIMARY KEY,
    NomRole VARCHAR(50),
    idPersonne INT NOT NULL,
    FOREIGN KEY (idPersonne) REFERENCES Personne(idPersonne)
);

---------------------------------------------------------
-- TABLE : PersonneAudit
---------------------------------------------------------
CREATE TABLE PersonneAudit (
    idAuditId INT IDENTITY(1,1) PRIMARY KEY,
    ActionType VARCHAR(50),
    OldNom VARCHAR(50),
    OldPrenom VARCHAR(50),
    OldEmail VARCHAR(50),
    OldTelephone INT,
    OldAdresse VARCHAR(50),
    NewNom VARCHAR(50),
    NewPrenom VARCHAR(50),
    NewEmail VARCHAR(50),
    NewTelephone INT,
    ActionDate DATE,
    NewAdresse VARCHAR(50),
    idPersonne INT NULL,
    FOREIGN KEY (idPersonne) REFERENCES Personne(idPersonne)
);

---------------------------------------------------------
-- TABLE : Commande
---------------------------------------------------------
CREATE TABLE Commande (
    idCommande INT IDENTITY(1,1) PRIMARY KEY,
    Quantité INT,
    idPersonne INT NOT NULL,
    FOREIGN KEY (idPersonne) REFERENCES Personne(idPersonne)
);

---------------------------------------------------------
-- TABLE : Article
---------------------------------------------------------
CREATE TABLE Article (
    idArticle INT IDENTITY(1,1) PRIMARY KEY,
    Nom_Article VARCHAR(50),
    Prix DECIMAL(15,2),
    Description VARCHAR(500),
    idCommande INT NOT NULL,
    FOREIGN KEY (idCommande) REFERENCES Commande(idCommande)
);

---------------------------------------------------------
-- TABLE : Animal
---------------------------------------------------------
CREATE TABLE Animal (
    idAnimal INT IDENTITY(1,1) PRIMARY KEY,
    Nom VARCHAR(50),
    Age INT,
    Sexe VARCHAR(50),
    Espece VARCHAR(50),
    idArticle INT NOT NULL,
    FOREIGN KEY (idArticle) REFERENCES Article(idArticle)
);

---------------------------------------------------------
-- TABLE : Mammifere
---------------------------------------------------------
CREATE TABLE Mammifere (
    idMammifere INT IDENTITY(1,1) PRIMARY KEY,
    Pelage VARCHAR(50),
    GestationJours TINYINT,
    idAnimal INT NOT NULL,
    FOREIGN KEY (idAnimal) REFERENCES Animal(idAnimal)
);

---------------------------------------------------------
-- TABLE : Reptile
---------------------------------------------------------
CREATE TABLE Reptile (
    idReptile INT IDENTITY(1,1) PRIMARY KEY,
    TypeEcailles VARCHAR(50),
    EstVenimeux BIT,
    idAnimal INT NOT NULL,
    FOREIGN KEY (idAnimal) REFERENCES Animal(idAnimal)
);

---------------------------------------------------------
-- TABLE : Oiseau
---------------------------------------------------------
CREATE TABLE Oiseau (
    idOiseau INT IDENTITY(1,1) PRIMARY KEY,
    Envergure DECIMAL(15,2),
    PeutVoler VARCHAR(50),
    idAnimal INT NOT NULL,
    FOREIGN KEY (idAnimal) REFERENCES Animal(idAnimal)
);
